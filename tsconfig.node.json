{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": "./dist-tsnode"
  },
  "include": [
    "electron/**/*.ts",
    "vite.config.ts"
  ]
}
