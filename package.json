{
  "name": "api-preview",
  "version": "1.5.0",
  "description": "ApiPreview — 轻量级 Swagger/OpenAPI 桌面阅读器 + 轻调试工具",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:tag": "node -p \"const v=require('./package.json').version; require('child_process').execSync('git add package.json && git commit -m \\\"chore: bump version to '+v+'\\\" && git tag v'+v+' && git push origin --tags', {stdio:'inherit', shell:true})\"",
    "preversion": "git diff --quiet HEAD || (echo Please commit/stash changes first && exit 1)"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "autoprefixer": "^10.5.4",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "build": {
    "appId": "com.yuxay.api-preview",
    "productName": "ApiPreview",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yuxay",
        "repo": "api-preview"
      }
    ],
    "files": [
      "brand/**",
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "icon": "build/icon.ico"
  }
}
